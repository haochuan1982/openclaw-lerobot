{
  "policy": {
    "name": "act",
    "source": {
      "class_path": "physicalai.policies.act.policy.ACT"
    }
  },
  "model": {
    "runner": {
      "class_path": "physicalai.inference.runners.single_pass.SinglePass"
    },
    "artifacts": {
      "openvino": "act.xml"
    },
    "preprocessors": [
      {
